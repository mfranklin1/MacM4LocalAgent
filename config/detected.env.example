# Example output of `make detect`. Generated for reference only.
CHIP="Apple M5 Max"
ARCH="arm64"
CORES_TOTAL=18
CORES_PERF=12
CORES_EFF=6
RAM_GB=128
GPU_CORES="40"
DISK_FREE_GB=900

QUANT_TIER="q8"
OLLAMA_TAG="qwen3-coder-next:80b-q8"

KV_CACHE_TYPE="q4_0"   # q4_0 is what current Ollama supports; tq3 will appear here once upstream lands it
LOCAL_LONG_CTX=131072

ROUTE_LONG_MAX=131072

LITELLM_PORT=4000
OLLAMA_PORT=11434
DASHBOARD_PORT=4001
CLAUDE_PROXY_PORT=4002

# Claude auth mode for LiteLLM escalations (Cline → Claude path).
# subscription (default): uses the macOS keychain OAuth token from the
#   logged-in claude.ai Team/Pro account — no API key required.
# apikey: uses ANTHROPIC_API_KEY from the environment instead.
CLAUDE_AUTH_MODE="subscription"

# Offline mode: forces the hybrid router to never attempt Claude calls.
# Use OFFLINE=1 on an airplane, in a tunnel, or any time you want a
# guaranteed-local session. When OFFLINE=1 (or `auto` + the network
# probe fails), every claude-* selection is rewritten to local-long
# and stamped with `offline_downgrade` in cost.db.
#
#   OFFLINE=1       -> force offline (skip probe)
#   OFFLINE=0       -> force online  (skip probe, trust caller)
#   OFFLINE=auto    -> probe api.anthropic.com:443 (default if unset)
#
# OFFLINE_STRICT=1 changes the behavior so an explicit Claude request
# raises an HTTP 503 instead of being silently downgraded. Useful for
# tests + CI where a silent downgrade would mask a misconfiguration.
OFFLINE=auto
OFFLINE_STRICT=0

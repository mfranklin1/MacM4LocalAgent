bench/results/

# Runtime databases
cost/cost.db
*.sqlite
*.sqlite3

# Host-specific config (machine-detected hardware tier).
# config/detected.env.example is the checked-in template. The real
# detected.env is generated by `make detect` and pins per-host values
# (chip, quant tier, MLX repo, etc.) -- never committed.
config/detected.env

# Build artifact: regenerated from config/litellm-config.yaml +
# detected.env by scripts/40-litellm.sh on every install. Even though
# we no longer template a master key into it, keeping this gitignored
# avoids merge churn from per-host port pins / model tags.
config/litellm-config.rendered.yaml


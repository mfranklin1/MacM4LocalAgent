<?xml version="1.0" encoding="UTF-8"?>
<!-- NOT loaded by default. Managed by backend_lifecycle.py. Requires TURBO_ENABLED=1 and mlx-lm turbo_kv_bits support. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>          <string>com.local.turbo-512k</string>
  <key>RunAtLoad</key>      <false/>
  <key>KeepAlive</key>      <false/>
  <key>WorkingDirectory</key><string>@@REPO_ROOT@@</string>
  <key>ProcessType</key>    <string>Interactive</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>          <string>@@REPO_ROOT@@/.venvs/mlx/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>          <string>@@HOME@@</string>
    <key>USER</key>          <string>@@USER@@</string>
    <key>TMPDIR</key>        <string>@@TMPDIR@@</string>
    <key>TURBO_ENABLED</key> <string>0</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>@@REPO_ROOT@@/.venvs/mlx/bin/python</string>
    <string>-m</string><string>mlx_lm.server</string>
    <string>--model</string><string>@@TURBO_MODEL_LOCAL_DIR@@</string>
    <string>--host</string><string>127.0.0.1</string>
    <string>--port</string><string>8085</string>
    <string>--max-tokens</string><string>524288</string>
  </array>
  <key>StandardOutPath</key> <string>@@HOME@@/Library/Logs/MacM4LocalAgent/turbo-512k.log</string>
  <key>StandardErrorPath</key><string>@@HOME@@/Library/Logs/MacM4LocalAgent/turbo-512k.log</string>
</dict>
</plist>
